# ==========================================
# PENGATURAN PRINT SKRIPSI OTOMATIS
# ==========================================

# Nama printer yang terdeteksi di Windows
NAMA_PRINTER="EPSON L120 Series"

# Nama file PDF skripsi yang mau diprint
NAMA_FILE="File_Testing.pdf"

# Waktu istirahat mesin (dalam menit)
WAKTU_ISTIRAHAT=4

# Daftar halaman yang mau diprint (pisahkan dengan koma)
# Tulis urutan batch dari kelompok paling belakang ke depan
# Contoh "91-115 ; 66-90 ; 41-65 ; 1,18-40"
BATCH_HALAMAN="2 ; 1"